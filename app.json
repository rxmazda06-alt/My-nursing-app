        "backgroundColor": "#0c1117"
      },
      "package": "com.scrublife.ncjmm.trainer",
      "runtimeVersion": {
        "policy": "appVersion"
      }
    },
    "plugins": [
      "expo-splash-screen",
      "expo-asset",
      "react-native-iap"
    ],
    "extra": {
